# Discord Bot トークン（Discord Developer Portal から取得）
DISCORD_BOT_TOKEN=your_bot_token_here

# Supabase（workers/ の wrangler secret と同じ値を設定）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# 公式Discordサーバー招待URL（⚠️ 要設定: guildCreate.ts のウェルカムメッセージに使用）
DISCORD_SERVER_URL=https://discord.gg/your-server

# App Store アプリURL（⚠️ 要設定: guildCreate.ts のウェルカムメッセージに使用）
APP_STORE_URL=https://apps.apple.com/app/your-app
